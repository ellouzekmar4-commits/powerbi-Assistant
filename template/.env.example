# ===== Copier ce fichier en ".env" et remplir avec VOTRE base =====

# Port local (changez si vous faites tourner plusieurs chatbots : 3000, 3001, ...)
PORT=3000

# Connexion a la base SQL Server
SQL_HOST=localhost
SQL_PORT=1433
SQL_DATABASE=NOM_DE_VOTRE_BASE
SQL_USER=chatbot_reader
SQL_PASSWORD=VOTRE_MOT_DE_PASSE

# Cle API Google Gemini (https://aistudio.google.com -> Get API key)
GEMINI_API_KEY=VOTRE_CLE_GEMINI

# Nom affiche dans l'entete du chat
ASSISTANT_NAME=Assistant IA

# Lien d'incorporation du rapport Power BI
# (Power BI Service -> ouvrir le rapport -> Fichier -> Incorporer -> Site web ou portail)
PBI_EMBED_URL=https://app.powerbi.com/reportEmbed?reportId=...&autoAuth=true&ctid=...
